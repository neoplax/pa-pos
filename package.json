{
  "name": "pa-pos",
  "version": "1.0.0",
  "description": "Sistema POS para Perros Americanos",
  "main": "src/main/index.js",
  "scripts": {
    "start": "npm run build:renderer && electron --no-sandbox .",
    "dev": "concurrently -k -n RENDERER,ELECTRON -c cyan,yellow \"npm run build:renderer:watch\" \"wait-on dist/index.html && electron --no-sandbox .\"",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode development",
    "build:renderer:watch": "webpack --config webpack.renderer.config.js --mode development --watch",
    "build:renderer:prod": "webpack --config webpack.renderer.config.js --mode production",
    "build:win": "npm run build:renderer:prod && electron-builder --win",
    "build:linux": "npm run build:renderer:prod && electron-builder --linux",
    "build:all": "npm run build:renderer:prod && electron-builder --win --linux",
    "release": "npm run build:renderer:prod && electron-builder --win --linux --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.neoplax.papos",
    "productName": "PA POS",
    "copyright": "Copyright © 2025 Perros Americanos",
    "publish": {
      "provider": "github",
      "owner": "neoplax",
      "repo": "pa-pos"
    },
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/database/**/*",
      "src/sync/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PA POS"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "googleapis": "^144.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@electron/rebuild": "^3.5.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
